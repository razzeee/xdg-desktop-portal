<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.portal.Language:
      @short_description: Portal for local language model tasks

      The Language portal lets sandboxed applications use local text model
      capabilities selected and governed by the system portal backend.

      This documentation describes version 4 of this interface.
  -->
  <interface name="org.freedesktop.portal.Language">
    <!--
        GetUseCaseAvailability:
        @use_case: Task token such as ``language.summarize`` or ``language.translate``
        @options: Vardict with optional further information
        @availability: Struct containing availability, code, and human-readable reason

        Returns whether a local profile is assigned and runnable for @use_case.
    -->
    <method name="GetUseCaseAvailability">
      <arg type="s" name="use_case" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In1" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="(bss)" name="availability" direction="out"/>
    </method>

    <!--
        CreateSession:
        @parent_window: Identifier for the application window, see :doc:`window-identifiers`
        @use_case: Task token beginning with ``language.``
        @instructions: Stable system instructions for this session
        @options: Vardict with optional further information
        @handle: Object path for the :ref:`org.freedesktop.portal.Request` object representing this call

        Creates a language model session. The session handle is returned in
        the :ref:`org.freedesktop.portal.Request::Response` signal using the
        ``session_handle`` key.
    -->
    <method name="CreateSession">
      <arg type="s" name="parent_window" direction="in"/>
      <arg type="s" name="use_case" direction="in"/>
      <arg type="s" name="instructions" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In3" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <method name="Prewarm">
      <arg type="o" name="session_handle" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In1" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <!--
        StreamResponse:

        Starts streaming a language response. Output chunks are emitted as
        TokenReceived signals for @session_handle while the method call is in
        progress; the method reply only indicates that streaming has finished.
        Clients should subscribe to TokenReceived before calling and consume
        signals concurrently with the method call.
    -->
    <method name="StreamResponse">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="prompt" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <!--
        StreamPredictNext:

        Starts inline prediction for @prefix. A newer call for the same session
        supersedes older in-flight prediction calls.
    -->
    <method name="StreamPredictNext">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="prefix" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <!--
        StreamRespondGuided:

        Starts streaming guided JSON snapshots. Snapshots are emitted as
        GuidedSnapshotReceived signals for @session_handle while the method call
        is in progress; the method reply only indicates that streaming has
        finished. Clients should subscribe before calling and consume signals
        concurrently with the method call.
    -->
    <method name="StreamRespondGuided">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="prompt" direction="in"/>
      <arg type="a(sssb)" name="fields" direction="in"/>
      <arg type="a(sss)" name="tools" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In4" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <method name="StreamSubmitToolResultsGuided">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="prompt" direction="in"/>
      <arg type="a(sss)" name="results" direction="in"/>
      <arg type="a(sssb)" name="fields" direction="in"/>
      <arg type="a(sss)" name="tools" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In5" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <method name="StreamEmbed">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="text" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="handle" direction="out"/>
    </method>

    <signal name="ModelLoading">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="s" name="message"/>
    </signal>

    <signal name="TokenReceived">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="s" name="token"/>
      <arg type="b" name="done"/>
    </signal>

    <signal name="PredictionReceived">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="s" name="completion"/>
      <arg type="b" name="done"/>
    </signal>

    <signal name="GuidedSnapshotReceived">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="s" name="snapshot_json"/>
      <arg type="b" name="done"/>
    </signal>

    <signal name="GuidedToolCallsReceived">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="a(sss)" name="tool_calls"/>
      <arg type="b" name="done"/>
    </signal>

    <signal name="EmbeddingReceived">
      <arg type="o" name="request_handle"/>
      <arg type="o" name="session_handle"/>
      <arg type="ad" name="embedding"/>
      <arg type="b" name="done"/>
    </signal>

    <property name="version" type="u" access="read"/>
  </interface>
</node>
