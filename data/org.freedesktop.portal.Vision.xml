<node name="/" xmlns:doc="http://www.freedesktop.org/dbus/1.0/doc.dtd">
  <!--
      org.freedesktop.portal.Vision:
      @short_description: Portal for local vision model tasks

      This documentation describes version 2 of this interface.
  -->
  <interface name="org.freedesktop.portal.Vision">
    <method name="GetUseCaseAvailability">
      <arg type="s" name="use_case" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In1" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="(bss)" name="availability" direction="out"/>
    </method>

    <!--
        CreateSession:
        @use_case: ``vision.describe`` for image descriptions,
          ``vision.ocr`` for text extraction, or ``vision.segment`` for object boxes
        @instructions: Stable system instructions for this session
        @options: Vardict with optional further information
        @session_handle: Object path for the :ref:`org.freedesktop.portal.Session` object

        The session @use_case selects which vision operation is permitted for
        the session. Create separate sessions for different vision tasks.
    -->
    <method name="CreateSession">
      <arg type="s" name="use_case" direction="in"/>
      <arg type="s" name="instructions" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
      <arg type="o" name="session_handle" direction="out"/>
    </method>

    <method name="Prewarm">
      <arg type="o" name="session_handle" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In1" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
    </method>

    <!--
        StreamDescribe:
        @session_handle: A ``vision.describe`` session handle returned by CreateSession
        @image: Base64-encoded PNG or JPEG image bytes; the encoded payload
          must fit within the session bus message limit
        @options: Vardict with optional further information
        Natural-language image description tokens are emitted as
        VisionTextReceived signals while this call is in progress.
    -->
    <method name="StreamDescribe">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="image" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
    </method>

    <!--
        StreamOcr:
        @session_handle: A ``vision.ocr`` session handle returned by CreateSession
        @image: Base64-encoded PNG or JPEG image bytes; the encoded payload
          must fit within the session bus message limit
        @options: Vardict with optional further information
        Text extracted from the image is emitted as VisionTextReceived signals
        while this call is in progress.
    -->
    <method name="StreamOcr">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="image" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
    </method>

    <!--
        StreamSegment:
        @session_handle: A ``vision.segment`` session handle returned by CreateSession
        @image: Base64-encoded PNG or JPEG image bytes; the encoded payload
          must fit within the session bus message limit
        @options: Vardict with optional further information
        Detected objects are emitted as VisionSegmentsReceived signals.

        Segment coordinates are normalized rectangles in the ``0.0..1.0``
        range relative to the image dimensions.
    -->
    <method name="StreamSegment">
      <arg type="o" name="session_handle" direction="in"/>
      <arg type="s" name="image" direction="in"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.In2" value="QVariantMap"/>
      <arg type="a{sv}" name="options" direction="in"/>
    </method>

    <signal name="ModelLoading">
      <arg type="o" name="session_handle"/>
      <arg type="s" name="message"/>
    </signal>

    <signal name="VisionTextReceived">
      <arg type="o" name="session_handle"/>
      <arg type="s" name="text"/>
      <arg type="b" name="done"/>
    </signal>

    <signal name="VisionSegmentsReceived">
      <arg type="o" name="session_handle"/>
      <arg type="a(sddddd)" name="segments"/>
      <arg type="b" name="done"/>
    </signal>

    <property name="version" type="u" access="read"/>
  </interface>
</node>
